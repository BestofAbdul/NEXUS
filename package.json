{
  "name": "nexus",
  "version": "0.1.0",
  "description": "An A2MCP autonomous mission agent built for the OKX.AI Genesis Hackathon.",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @nexus/web build",
    "dev": "pnpm --filter @nexus/web dev",
    "lint": "pnpm --filter @nexus/web typecheck",
    "mission:verify": "pnpm --filter @nexus/mission-engine verify",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  }
}

# Local development default. Prisma resolves this relative to its schema.
DATABASE_URL=file:./dev.db

# Railway injects PORT automatically. These values are useful outside Railway.
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=development

# Optional Amadeus Self-Service provider. Travel missions continue without it;
# flight tasks report "No flight provider configured". Never commit real values.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENVIRONMENT=test

# Default evidence provider for immigration, universities, jobs, housing,
# healthcare, government guidance, relocation, events, freight, and other
# research capabilities. Never commit a real value.
TAVILY_API_KEY=

# Railway production value after mounting a volume at the documented path:
# DATABASE_URL=file:/app/packages/mission-engine/prisma/dev.db

# Local development default. Prisma resolves this relative to its schema.
DATABASE_URL=file:./dev.db

# Railway injects PORT automatically. These values are useful outside Railway.
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=development

# Railway production value after mounting a volume at the documented path:
# DATABASE_URL=file:/app/packages/mission-engine/prisma/dev.db

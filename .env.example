# Local development default. Prisma resolves this relative to its schema.
DATABASE_URL=file:./dev.db

# Railway injects PORT automatically. These values are useful outside Railway.
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=development

# Amadeus Self-Service flight APIs. Create an application in the Amadeus
# developer portal and use test credentials first. Never commit real values.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENVIRONMENT=test

# Current web evidence with source URLs for immigration, universities, jobs,
# housing, healthcare, government guidance, and other workflow capabilities.
TAVILY_API_KEY=

# Railway production value after mounting a volume at the documented path:
# DATABASE_URL=file:/app/packages/mission-engine/prisma/dev.db

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Mission {
  id               String   @id @default(cuid())
  title            String
  type             String
  status           String   @default("DRAFT")
  goal             String
  setupAnswersJson String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tasks            Task[]
  researchResults  MissionResearchResult[]
}

model Task {
  id        String   @id @default(cuid())
  missionId String
  title     String
  status    String   @default("NOT_STARTED")
  dueAt     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
}

model MissionResearchResult {
  id         String   @id @default(cuid())
  missionId  String
  providerId String
  capability String
  summary    String
  dataJson   String
  createdAt  DateTime @default(now())
  mission    Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
}

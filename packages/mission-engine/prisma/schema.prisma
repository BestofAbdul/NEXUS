generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Mission {
  id               String   @id @default(cuid())
  title            String
  type             String
  status           String   @default("DRAFT")
  goal             String
  setupAnswersJson String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tasks            Task[]
  researchResults  MissionResearchResult[]
  recommendations  Recommendation[]
  costEstimates    CostEstimate[]
  notifications    MissionNotification[]
  timeline         TimelineEntry[]
}

model Task {
  id        String   @id @default(cuid())
  missionId String
  key       String?
  title     String
  description String @default("")
  capability String @default("manual")
  sequence Int @default(0)
  required Boolean @default(true)
  status    String   @default("NOT_STARTED")
  blockedReason String?
  dueAt     DateTime?
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@unique([missionId, key])
}

model MissionResearchResult {
  id         String   @id @default(cuid())
  missionId  String
  providerId String
  capability String
  taskKey    String?
  summary    String
  confidenceScore Float @default(0.5)
  dataJson   String
  sourceUrlsJson String @default("[]")
  retrievedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  mission    Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@unique([missionId, taskKey])
}

model Recommendation {
  id        String   @id @default(cuid())
  missionId String
  title     String
  summary   String
  rationale String
  rank      Int
  createdAt DateTime @default(now())
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@unique([missionId, rank])
}

model CostEstimate {
  id        String   @id @default(cuid())
  missionId String
  category  String
  amount    Float
  currency  String
  notes     String?
  createdAt DateTime @default(now())
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@unique([missionId, category])
}

model MissionNotification {
  id        String   @id @default(cuid())
  missionId String
  message   String
  createdAt DateTime @default(now())
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@unique([missionId, message])
}

model TimelineEntry {
  id         String   @id @default(cuid())
  missionId  String
  taskId     String?
  kind       String
  message    String
  occurredAt DateTime @default(now())
  mission    Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId, occurredAt])
  @@index([taskId])
}

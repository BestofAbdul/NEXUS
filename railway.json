{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @nexus/mission-engine db:generate && pnpm build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @nexus/mission-engine db:push && pnpm --filter @nexus/web start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
